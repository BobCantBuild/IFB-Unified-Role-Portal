{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*",        "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/social", "dest": "/api/social-feed.js" },
    { "src": "/api/(.*)",   "dest": "/api/$1.js" },
    { "src": "/(.*)",       "dest": "/$1" }
  ],
  "crons": [
    { "path": "/api/social?refresh=1", "schedule": "0 3 * * *" },
    { "path": "/api/news",             "schedule": "0 3 * * *" }
  ]
}