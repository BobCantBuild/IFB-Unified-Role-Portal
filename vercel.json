{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*",        "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/(.*)",     "dest": "/$1" }
  ],
  "crons": [
  { "path": "/api/social-cron",    "schedule": "0 9 * * *" },
  { "path": "/api/social-collect", "schedule": "1 9 * * *" },
  { "path": "/api/news",           "schedule": "0 8 * * *" }
  ]
}